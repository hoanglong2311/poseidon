# --- GreenNode MaaS (LLM, OpenAI-compatible) ---
# Key: dùng LLM_API_KEY (chuẩn skill) HOẶC AI_PLATFORM_API_KEY (chuẩn sample BTC) — code đọc cả hai.
LLM_API_KEY=
# AI_PLATFORM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL_CHAT=minimax/minimax-m2.5
LLM_MODEL_CLASSIFY=qwen/qwen3-5-27b
LLM_MODEL_RERANK=qwen/qwen3-reranker-8b

# --- Jira / Confluence (Account Jira Recon) ---
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=

# JQL scope
JIRA_PROJECTS=OS,ZPI
JIRA_ISSUE_TYPES=            # để trống = mọi type; vd "Support,Production Support" để siết
JIRA_TEAM_ACCOUNT_IDS=        # comma-separated Jira accountIds of team members

# --- Notifier (ADR 0010): zalo (default) | telegram (fallback) ---
NOTIFY_BACKEND=zalo
# Zalo API host = bot-api.zapps.me (verified qua scripts/zalo-bot-test.mjs), KHÔNG phải zaloplatforms.com
ZALO_BASE_URL=https://bot-api.zapps.me
# Token: ZALO_BOT_TOKEN hoặc BOT_ZALO_TOKEN đều đọc được
ZALO_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
# Seed mapping jira_account -> chat_id (SQLite container ephemeral). JSON 1 dòng:
# SEED_CHAT_IDS={"<accountId>":{"chat_id":"...","name":"..."}}
SEED_CHAT_IDS=

# --- App ---
DB_PATH=poseidon.db
TZ=Asia/Ho_Chi_Minh

# --- Auth (Chainlit OAuth Google) ---
# CHAINLIT_AUTH_SECRET: JWT signing secret (tạo bằng `chainlit create-secret`)
CHAINLIT_AUTH_SECRET=
# CHAINLIT_URL: public URL của agent (cho OAuth redirect). = endpoint AgentBase sau deploy.
CHAINLIT_URL=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Giới hạn ai đăng nhập được (để trống = cho mọi tài khoản Google):
AUTH_ALLOWED_EMAILS=        # vd: longhoangnguyen191@gmail.com,quang@...
AUTH_ALLOWED_DOMAIN=        # vd: vng.com.vn (cho phép mọi email @vng.com.vn)

# Trang Runbook index (children = các runbook). Default OPF-RC Runbook.
CONFLUENCE_RUNBOOK_PAGE_ID=360449

# Secret cho Zalo webhook (>=8 ký tự) — verify header X-Bot-Api-Secret-Token
ZALO_WEBHOOK_SECRET=
